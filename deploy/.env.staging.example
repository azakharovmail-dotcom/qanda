# ── deploy/.env.staging ──────────────────────────────────────────────────
# Runtime server env for the STAGING container (app-staging,
# staging.qanda.online). Copy to deploy/.env.staging (gitignored).
# Reuses the same qanda:latest image as prod — only the runtime env differs.

NODE_ENV=production

# Absolute base URL for staging. Preferred at runtime over the build-time
# NEXT_PUBLIC_SITE_URL (see lib/env.ts) — THIS is what makes one image serve
# staging with correct absolute URLs.
SITE_URL=https://staging.qanda.online

# Supabase Cloud — same project as prod for now (shared DB).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLISHABLE_KEY

# Server-only secret — writes that bypass RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Server-only secret — signs anonymous participant tokens.
# Generate with:  openssl rand -base64 48
ANON_SECRET=CHANGE_ME_openssl_rand_base64_48

# Optional — Upstash Redis for rate limiting. Leave unset to disable (no-op).
# UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
# UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN
