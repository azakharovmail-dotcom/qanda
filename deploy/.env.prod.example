# ── deploy/.env.prod ─────────────────────────────────────────────────────
# Runtime server env for the PROD container (app-prod, qanda.online).
# Copy to deploy/.env.prod (gitignored) and fill in the real values.
# These are injected at RUNTIME via env_file — server-only secrets are NOT
# baked into the image.

NODE_ENV=production

# Absolute base URL for this environment. Preferred at runtime over the
# build-time NEXT_PUBLIC_SITE_URL (see lib/env.ts) so one image serves both envs.
SITE_URL=https://qanda.online

# Supabase Cloud — public values (also passed as build args for app-prod so
# the NEXT_PUBLIC_* get inlined into the client bundle).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLISHABLE_KEY

# Server-only secret — writes that bypass RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Server-only secret — signs anonymous participant tokens.
# Generate with:  openssl rand -base64 48
ANON_SECRET=CHANGE_ME_openssl_rand_base64_48

# Optional — Upstash Redis for rate limiting. Leave unset to disable (no-op).
# UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
# UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN
